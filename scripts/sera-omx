#!/usr/bin/env bash
# sera-omx — Launch an OMX (Codex) session with clawhip monitoring
#
# Usage:
#   sera-omx                          # auto-generated session name
#   sera-omx <bead-id>                # claim bead + named session
#   sera-omx <bead-id> [omx-args...]  # pass extra args to omx

set -euo pipefail

DISCORD_CHANNEL="1492957434690670713"
KEYWORDS="✻ Worked for,● APPROVED,✓ Closed,compile error,thread panicked,FATAL"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SERA_ROOT="$(git -C "$SCRIPT_DIR" rev-parse --show-toplevel 2>/dev/null || echo "$SCRIPT_DIR/..")"

BEAD_ID=""
OMX_ARGS=()

if [[ $# -gt 0 ]] && [[ "$1" =~ ^[a-zA-Z][a-zA-Z0-9]*-[a-zA-Z0-9]+$ ]]; then
  BEAD_ID="$1"
  shift
fi
OMX_ARGS=("$@")

if [[ -n "$BEAD_ID" ]]; then
  SESSION="omc-sera-${BEAD_ID}"
  echo "[sera-omx] Claiming bead ${BEAD_ID}..."
  bd update "${BEAD_ID}" --claim 2>/dev/null || true
else
  SESSION="omc-sera-$(date +%s | rev | cut -c1-4)"
fi

echo "[sera-omx] Starting monitored session: ${SESSION}"

exec clawhip tmux new \
  --session "${SESSION}" \
  --channel "${DISCORD_CHANNEL}" \
  --keywords "${KEYWORDS}" \
  --cwd "${SERA_ROOT}" \
  --attach \
  -- omx "${OMX_ARGS[@]+"${OMX_ARGS[@]}"}"
