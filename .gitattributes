# Normalize all text files to LF in the repo and on checkout.
# This prevents CRLF ghost diffs on Windows (core.autocrlf=true).
* text=auto eol=lf

# Ensure shell scripts always use LF line endings (required for Linux containers)
*.sh text eol=lf
*.conf text eol=lf
entrypoint* text eol=lf

# Dockerfiles should also use LF
Dockerfile* text eol=lf

# Binary files — do not normalize
*.png binary
*.jpg binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
