# ── SERA Environment Variables ────────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# ── Core (sera-core) ──
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://sera_user:sera_pass@sera-db:5432/sera_db
CENTRIFUGO_API_URL=http://centrifugo:8000/api
QDRANT_URL=http://qdrant:6333
WORKSPACE_DIR=/app/workspace # Internal to container
HOST_WORKSPACES_DIR=./workspaces # Path on your host machine
JWT_SECRET=sera-ephemeral-secret-change-me # Secret for JWT signing

# ── LiteLLM Gateway ──
LITELLM_MASTER_KEY=sk-sera-master-key-change-me
LLM_BASE_URL=http://litellm:4000/v1
LLM_API_KEY=sk-sera-master-key-change-me # Should match LITELLM_MASTER_KEY

# ── Upstream LLM Providers (Optional) ──
# LiteLLM will ignore these if left blank.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Web (sera-web) ──
NEXT_PUBLIC_CENTRIFUGO_URL=ws://localhost:10001/connection/websocket
CORE_API_URL=http://localhost:3001

# ── Database (sera-db) ──
POSTGRES_USER=sera_user
POSTGRES_PASSWORD=sera_pass
POSTGRES_DB=sera_db

# ── Centrifugo ──
# Centrifugo config is in ./centrifugo/config.json
