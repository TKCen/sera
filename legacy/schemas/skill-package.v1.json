{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SkillPackage V1",
  "type": "object",
  "required": ["name", "version", "skills"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
      "maxLength": 63,
      "description": "Unique kebab-case identifier for the package"
    },
    "version": {
      "type": "string",
      "description": "Semver version of the package"
    },
    "description": {
      "type": "string"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" }
        }
      },
      "description": "List of skills included in this package"
    }
  }
}
