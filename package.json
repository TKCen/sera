{
  "name": "sera",
  "private": true,
  "type": "module",
  "workspaces": ["core", "web"],
  "scripts": {
    "postinstall": "echo 'Run npm run hooks:install to set up git hooks'",

    "dev:up":    "docker compose -f docker-compose.yaml -f docker-compose.dev.yaml up -d",
    "dev:down":  "docker compose -f docker-compose.yaml -f docker-compose.dev.yaml down",
    "dev:logs":  "docker compose -f docker-compose.yaml -f docker-compose.dev.yaml logs -f",

    "prod:up":   "docker compose -f docker-compose.yaml up -d",
    "prod:down": "docker compose -f docker-compose.yaml down",
    "prod:logs": "docker compose -f docker-compose.yaml logs -f",

    "prod:auth:up":   "docker compose -f docker-compose.yaml -f docker-compose.auth.yaml up -d",
    "prod:auth:down": "docker compose -f docker-compose.yaml -f docker-compose.auth.yaml down",
    "prod:auth:logs": "docker compose -f docker-compose.yaml -f docker-compose.auth.yaml logs -f",

    "typecheck":      "npm run typecheck --workspaces --if-present",
    "typecheck:core": "npm run typecheck --workspace=core",
    "typecheck:web":  "npm run typecheck --workspace=web",

    "lint":      "npm run lint --workspaces --if-present",
    "lint:core": "npm run lint --workspace=core",
    "lint:web":  "npm run lint --workspace=web",

    "format":            "npm run format --workspaces --if-present",
    "format:core":       "npm run format --workspace=core",
    "format:web":        "npm run format --workspace=web",
    "format:check":      "npm run format:check --workspaces --if-present",
    "format:check:core": "npm run format:check --workspace=core",
    "format:check:web":  "npm run format:check --workspace=web",

    "test":             "npm run test --workspaces --if-present",
    "test:unit":        "npm run test:unit --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "test:core":        "npm run test --workspace=core",
    "test:web":         "npm run test --workspace=web",
    "test:tui":         "cd tui && go test ./...",

    "build":      "npm run build --workspaces --if-present && npm run build:tui",
    "build:core": "npm run build --workspace=core",
    "build:web":  "npm run build --workspace=web",
    "build:tui":  "cd tui && go build -o tui.exe .",

    "check-all": "npm run format && npm run lint && npm run typecheck && npm run test && npm run build",

    "pre-commit":    "npm run typecheck && npm run lint && npm run test:web",

    "hooks:install": "node scripts/install-hooks.js",
    "tui:build":     "cd tui && go build -o tui.exe ."
  }
}
