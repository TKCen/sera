{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SandboxBoundary V1",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "linux", "capabilities"],
  "properties": {
    "apiVersion": { "const": "sera/v1" },
    "kind": { "const": "SandboxBoundary" },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "linux": {
      "type": "object",
      "required": ["capabilities", "seccomp"],
      "properties": {
        "capabilities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "seccomp": { "type": "string" },
        "readonlyRootfs": { "type": "boolean" },
        "runAsNonRoot": { "type": "boolean" }
      }
    },
    "capabilities": {
      "type": "object"
    }
  }
}
